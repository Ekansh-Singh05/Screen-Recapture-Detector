# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
.Python
build/
dist/
*.egg-info/
.eggs/

# ── Virtual environments ───────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Jupyter ────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDEs ───────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Project artefacts (generated — do not commit) ─────────────────────────
