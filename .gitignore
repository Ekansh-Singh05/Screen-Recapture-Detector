outputs/logs/

# ── Data (may contain PII / large files) ──────────────────────────────────
data/real/*
!data/real/.gitkeep
data/screen/*
!data/screen/.gitkeep

# ── OS ────────────────────────────────────────────────────────────────────
desktop.ini

# ── Secrets ───────────────────────────────────────────────────────────────
.env
*.key
*.pem
secrets.yaml
